# Build-time vars (inlined into client JS by Vite):
VITE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_token
VITE_LISTINGS_WEBHOOK_URL=https://discord.com/api/webhooks/your_listings_webhook_id/your_token
VITE_ADMIN_PASSWORD=your_admin_password

# Runtime vars (set via Cloudflare Worker vars/secrets, or in .dev.vars for local dev):
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
DISCORD_GUILD_ID=your_guild_id
JWT_SECRET=your_jwt_secret
APP_URL=http://localhost:3000
